Grammar

    0 $accept: input "end of file"

    1 input: expression

    2 expression: assigment
    3           | command
    4           | logicalOr
    5           | illegal

    6 logicalOr: logicalOr oOR logicalXor
    7          | logicalXor

    8 logicalXor: logicalXor oXOR logicalAnd
    9           | logicalAnd

   10 logicalAnd: logicalAnd oAND logicalNot
   11           | logicalAnd oNAND logicalNot
   12           | logicalNot

   13 logicalNot: oNOT logicalNot
   14           | relational

   15 relational: relational "<" additive
   16           | relational ">" additive
   17           | relational oLE additive
   18           | relational oGE additive
   19           | relational oEQ additive
   20           | relational oNE additive
   21           | additive

   22 additive: additive "+" multiplicative
   23         | additive "-" multiplicative
   24         | multiplicative

   25 multiplicative: multiplicative "*" power
   26               | multiplicative "/" power
   27               | power

   28 power: unary "^" power
   29      | unary

   30 unary: "-" unary
   31      | "+" unary
   32      | primary

   33 primary: number
   34        | function
   35        | "(" expression ")"
   36        | attribute
   37        | variable
   38        | formula

   39 number: NUMD
   40       | NUMH

   41 command: commandIF
   42        | commandFOR

   43 commandIF: cIF "(" expression "," expression "," expression ")"
   44          | cIF "(" expression "," expression ")"

   45 commandFOR: cFOR variable "=" expression cTO expression cDO assigment
   46           | cFOR attribute "=" expression cTO expression cDO assigment

   47 function: mathFunction
   48         | trigonFunction
   49         | probFunction
   50         | kernelFunction
   51         | elementFunction
   52         | pluginFunction
   53         | userFunction

   54 kernelFunction: fTNOW
   55               | fTFIN
   56               | fMAXREP
   57               | fNUMREP
   58               | fIDENT
   59               | simulEntitiesWIP

   60 elementFunction: fTAVG "(" CSTAT ")"
   61                | fCOUNT "(" COUNTER ")"

   62 trigonFunction: fSIN "(" expression ")"
   63               | fCOS "(" expression ")"

   64 mathFunction: fROUND "(" expression ")"
   65             | fFRAC "(" expression ")"
   66             | fTRUNC "(" expression ")"
   67             | fEXP "(" expression ")"
   68             | fSQRT "(" expression ")"
   69             | fLOG "(" expression ")"
   70             | fLN "(" expression ")"
   71             | fMOD "(" expression "," expression ")"
   72             | mathMIN "(" expression "," expression ")"
   73             | mathMAX "(" expression "," expression ")"

   74 probFunction: fRND1
   75             | fEXPO "(" expression ")"
   76             | fNORM "(" expression "," expression ")"
   77             | fUNIF "(" expression "," expression ")"
   78             | fWEIB "(" expression "," expression ")"
   79             | fLOGN "(" expression "," expression ")"
   80             | fGAMM "(" expression "," expression ")"
   81             | fERLA "(" expression "," expression ")"
   82             | fTRIA "(" expression "," expression "," expression ")"
   83             | fBETA "(" expression "," expression "," expression "," expression ")"
   84             | fDISC "(" listaparm ")"

   85 userFunction: "USER" "(" expression ")"

   86 listaparm: listaparm "," expression "," expression
   87          | expression "," expression

   88 illegal: ILLEGAL

   89 attribute: ATRIB
   90          | ATRIB "[" expression "]"
   91          | ATRIB "[" expression "," expression "]"
   92          | ATRIB "[" expression "," expression "," expression "]"

   93 variable: VARI
   94         | VARI "[" expression "]"
   95         | VARI "[" expression "," expression "]"
   96         | VARI "[" expression "," expression "," expression "]"

   97 formula: FORM
   98        | FORM "[" expression "]"
   99        | FORM "[" expression "," expression "]"
  100        | FORM "[" expression "," expression "," expression "]"

  101 assigment: ATRIB "=" expression
  102          | ATRIB "[" expression "]" "=" expression
  103          | ATRIB "[" expression "," expression "]" "=" expression
  104          | ATRIB "[" expression "," expression "," expression "]" "=" expression
  105          | VARI "=" expression
  106          | VARI "[" expression "]" "=" expression
  107          | VARI "[" expression "," expression "]" "=" expression
  108          | VARI "[" expression "," expression "," expression "]" "=" expression

  109 pluginFunction: CTEZERO
  110               | fNQ "(" QUEUE ")"
  111               | fLASTINQ "(" QUEUE ")"
  112               | fFIRSTINQ "(" QUEUE ")"
  113               | fSAQUE "(" QUEUE "," ATRIB ")"
  114               | fAQUE "(" QUEUE "," NUMD "," ATRIB ")"
  115               | fMR "(" RESOURCE ")"
  116               | fNR "(" RESOURCE ")"
  117               | fRESSEIZES "(" RESOURCE ")"
  118               | fSTATE "(" RESOURCE ")"
  119               | fIRF "(" RESOURCE ")"
  120               | fSETSUM "(" SET ")"
  121               | fNUMSET "(" SET ")"


