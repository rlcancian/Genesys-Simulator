Grammar

    0 $accept: input "end of file"

    1 input: expression

    2 expression: number
    3           | function
    4           | command
    5           | assigment
    6           | arithmetic
    7           | logical
    8           | relacional
    9           | "(" expression ")"
   10           | attribute
   11           | illegal
   12           | variable
   13           | formula

   14 number: NUMD
   15       | NUMH

   16 arithmetic: expression "+" expression
   17           | expression "-" expression
   18           | expression "/" expression
   19           | expression "*" expression
   20           | expression "^" expression
   21           | "-" expression
   22           | mathMIN "(" expression "," expression ")"
   23           | mathMAX "(" expression "," expression ")"

   24 logical: expression oAND expression
   25        | expression oOR expression
   26        | expression oNAND expression
   27        | expression oXOR expression
   28        | oNOT expression

   29 relacional: expression "<" expression
   30           | expression ">" expression
   31           | expression oLE expression
   32           | expression oGE expression
   33           | expression oEQ expression
   34           | expression oNE expression

   35 command: commandIF
   36        | commandFOR

   37 commandIF: cIF expression expression cELSE expression
   38          | cIF expression expression

   39 commandFOR: cFOR variable "=" expression cTO expression cDO assigment
   40           | cFOR attribute "=" expression cTO expression cDO assigment

   41 function: mathFunction
   42         | trigonFunction
   43         | probFunction
   44         | kernelFunction
   45         | elementFunction
   46         | pluginFunction
   47         | userFunction

   48 kernelFunction: fTNOW
   49               | fTFIN
   50               | fMAXREP
   51               | fNUMREP
   52               | fIDENT
   53               | simulEntitiesWIP

   54 elementFunction: ε
   55                | fTAVG "(" CSTAT ")"
   56                | fCOUNT "(" COUNTER ")"

   57 trigonFunction: fSIN "(" expression ")"
   58               | fCOS "(" expression ")"

   59 mathFunction: fROUND "(" expression ")"
   60             | fFRAC "(" expression ")"
   61             | fTRUNC "(" expression ")"
   62             | fEXP "(" expression ")"
   63             | fSQRT "(" expression ")"
   64             | fLOG "(" expression ")"
   65             | fLN "(" expression ")"
   66             | fMOD "(" expression "," expression ")"

   67 probFunction: fRND1
   68             | fEXPO "(" expression ")"
   69             | fNORM "(" expression "," expression ")"
   70             | fUNIF "(" expression "," expression ")"
   71             | fWEIB "(" expression "," expression ")"
   72             | fLOGN "(" expression "," expression ")"
   73             | fGAMM "(" expression "," expression ")"
   74             | fERLA "(" expression "," expression ")"
   75             | fTRIA "(" expression "," expression "," expression ")"
   76             | fBETA "(" expression "," expression "," expression "," expression ")"
   77             | fDISC "(" listaparm ")"

   78 userFunction: "USER" "(" expression ")"

   79 listaparm: listaparm "," expression "," expression
   80          | expression "," expression

   81 illegal: ILLEGAL

   82 attribute: ATRIB
   83          | ATRIB "[" expression "]"
   84          | ATRIB "[" expression "," expression "]"
   85          | ATRIB "[" expression "," expression "," expression "]"

   86 variable: VARI
   87         | VARI "[" expression "]"
   88         | VARI "[" expression "," expression "]"
   89         | VARI "[" expression "," expression "," expression "]"

   90 formula: FORM
   91        | FORM "[" expression "]"
   92        | FORM "[" expression "," expression "]"
   93        | FORM "[" expression "," expression "," expression "]"

   94 assigment: ATRIB "=" expression
   95          | ATRIB "[" expression "]" "=" expression
   96          | ATRIB "[" expression "," expression "]" "=" expression
   97          | ATRIB "[" expression "," expression "," expression "]" "=" expression
   98          | VARI "=" expression
   99          | VARI "[" expression "]" "=" expression
  100          | VARI "[" expression "," expression "]" "=" expression
  101          | VARI "[" expression "," expression "," expression "]" "=" expression

  102 pluginFunction: CTEZERO
  103               | fNQ "(" QUEUE ")"
  104               | fLASTINQ "(" QUEUE ")"
  105               | fFIRSTINQ "(" QUEUE ")"
  106               | fSAQUE "(" QUEUE "," ATRIB ")"
  107               | fAQUE "(" QUEUE "," NUMD "," ATRIB ")"
  108               | fMR "(" RESOURCE ")"
  109               | fNR "(" RESOURCE ")"
  110               | fRESSEIZES "(" RESOURCE ")"
  111               | fSTATE "(" RESOURCE ")"
  112               | fIRF "(" RESOURCE ")"
  113               | fSETSUM "(" SET ")"
  114               | fNUMSET "(" SET ")"


