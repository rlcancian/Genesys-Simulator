{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "GENESYS_BUILD_GUI_APPLICATION": "OFF",
        "GENESYS_BUILD_WEB_APPLICATION": "OFF",
        "GENESYS_BUILD_PLUGINS": "ON",
        "GENESYS_BUILD_PARSER": "ON",
        "GENESYS_BUILD_KERNEL": "ON",
        "GENESYS_BUILD_TERMINAL_APPLICATION": "OFF"
      }
    },
    {
      "name": "debug-base",
      "hidden": true,
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "GENESYS_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "tests-unit",
      "displayName": "Tests - Unit",
      "inherits": "debug-base",
      "binaryDir": "${sourceDir}/build/tests-unit",
      "cacheVariables": {
        "GENESYS_BUILD_TESTS": "ON",
        "GENESYS_BUILD_SMOKE_TESTS": "OFF",
        "GENESYS_BUILD_TERMINAL_APPLICATION": "OFF"
      }
    },
    {
      "name": "tests-kernel-unit",
      "displayName": "Tests - Kernel Unit",
      "inherits": "tests-unit",
      "binaryDir": "${sourceDir}/build/tests-kernel-unit",
      "cacheVariables": {
        "GENESYS_BUILD_TESTS": "ON",
        "GENESYS_BUILD_SMOKE_TESTS": "OFF",
        "GENESYS_BUILD_TERMINAL_APPLICATION": "OFF"
      }
    },
    {
      "name": "terminal-app",
      "displayName": "Application - Terminal (GenesysShell)",
      "inherits": "debug-base",
      "binaryDir": "${sourceDir}/build/terminal-app",
      "cacheVariables": {
        "GENESYS_BUILD_TESTS": "OFF",
        "GENESYS_BUILD_TERMINAL_APPLICATION": "ON",
        "GENESYS_TERMINAL_APP": "GenesysShell"
      }
    },
    {
      "name": "terminal-example",
      "displayName": "Application - Terminal Example",
      "inherits": "terminal-app",
      "binaryDir": "${sourceDir}/build/terminal-example",
      "cacheVariables": {
        "GENESYS_TERMINAL_EXAMPLE": "smarts/Smart_AssignWriteSeizes.cpp"
      }
    },
    {
      "name": "terminal-smart-hold-search-remove",
      "displayName": "Application - Terminal Example (Smart_HoldSearchRemove)",
      "inherits": "terminal-app",
      "binaryDir": "${sourceDir}/build/terminal-smart-hold-search-remove",
      "cacheVariables": {
        "GENESYS_TERMINAL_EXAMPLE": "smarts/Smart_HoldSearchRemove.cpp"
      }
    },
    {
      "name": "web-app",
      "displayName": "Application - Web",
      "inherits": "debug-base",
      "binaryDir": "${sourceDir}/build/web-app",
      "cacheVariables": {
        "GENESYS_BUILD_TESTS": "OFF",
        "GENESYS_BUILD_WEB_APPLICATION": "ON",
        "GENESYS_BUILD_TERMINAL_APPLICATION": "OFF"
      }
    },
    {
      "name": "gui-app",
      "displayName": "Application - GUI",
      "inherits": "debug-base",
      "binaryDir": "${sourceDir}/build/gui-app",
      "cacheVariables": {
        "GENESYS_BUILD_TESTS": "OFF",
        "GENESYS_BUILD_GUI_APPLICATION": "ON",
        "GENESYS_BUILD_TERMINAL_APPLICATION": "OFF"
      }
    },
    {
      "name": "tests-smoke",
      "displayName": "Tests - Smoke",
      "inherits": "debug-base",
      "binaryDir": "${sourceDir}/build/tests-smoke",
      "cacheVariables": {
        "GENESYS_BUILD_TESTS": "ON",
        "GENESYS_BUILD_SMOKE_TESTS": "ON",
        "GENESYS_BUILD_TERMINAL_APPLICATION": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "tests-unit",
      "configurePreset": "tests-unit",
      "targets": [
        "genesys_kernel_unit_tests"
      ]
    },
    {
      "name": "tests-kernel-unit-run",
      "configurePreset": "tests-kernel-unit",
      "targets": [
        "genesys_kernel_unit_tests_run"
      ]
    },
    {
      "name": "terminal-app",
      "configurePreset": "terminal-app",
      "targets": [
        "genesys_terminal_application"
      ]
    },
    {
      "name": "terminal-example",
      "configurePreset": "terminal-example",
      "targets": [
        "genesys_terminal_application"
      ]
    },
    {
      "name": "terminal-smart-hold-search-remove",
      "configurePreset": "terminal-smart-hold-search-remove",
      "targets": [
        "genesys_terminal_application"
      ]
    },
    {
      "name": "web-app",
      "configurePreset": "web-app",
      "targets": [
        "genesys_webhook"
      ]
    },
    {
      "name": "gui-app",
      "configurePreset": "gui-app",
      "targets": [
        "genesys_gui"
      ]
    },
    {
      "name": "tests-smoke",
      "configurePreset": "tests-smoke",
      "targets": [
        "genesys_smoke_tests"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "tests-unit",
      "configurePreset": "tests-unit",
      "filter": {
        "include": {
          "label": "unit"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-kernel-unit",
      "configurePreset": "tests-kernel-unit",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-smoke",
      "configurePreset": "tests-smoke",
      "filter": {
        "include": {
          "label": "smoke"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
