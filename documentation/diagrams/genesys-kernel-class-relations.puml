@startuml
' GenESyS — kernel class relation diagram, branch WiP20261
' Scope: source/kernel and nested kernel subpackages with class relations.
' Class-relation diagram: attributes and methods intentionally omitted.

top to bottom direction
skinparam linetype polyline
skinparam shadowing false
skinparam nodesep 48
skinparam ranksep 64
skinparam backgroundColor transparent
skinparam classBackgroundColor #FFFFF0
skinparam interfaceBackgroundColor #FFFFF0
skinparam packageBackgroundColor #F8F8FF
skinparam packageBorderColor #707080
skinparam ArrowColor #505060
skinparam classBorderColor #707080

package "kernel" #F8F8FF {
  package "kernel/util" #F8F8FF {
    class Util
    class "List<T>"
    class "ListObservable<T>"
  }

  package "kernel/statistics" #F8F8FF {
    interface Collector_if
    interface Statistics_if
    interface Sampler_if
    class CollectorDefaultImpl1
    class StatisticsDefaultImpl1
  }

  package "kernel/simulator" #F8F8FF {
    class Simulator
    class LicenceManager
    class PluginManager
    class Plugin
    class PluginInformation
    interface PluginConnector_if
    class PluginLoadIssue
    class SystemDependencyResolver
    interface SystemCommandExecutor_if
    class SystemShellCommandExecutor
    class SystemDependencyCheckResult
    class SystemDependencyInstallResult

    class SourceModelComponent
    class ConnectionManager
    class Connection
    class Event
    class TraceManager
    class TraceEvent
    class TraceErrorEvent
    class TraceSimulationEvent
    class OnEventManager
    class ModelEvent
    class SimulationEvent

    interface Parser_if
    class ParserDefaultImpl1
    class ParserManager
    class ParserChangesInformation
    class Persistence
    class PersistenceRecord
    abstract class PersistentObject_base
    class ExperimentManager
    class SimulationExperiment
    class SimulationScenario
    class SimulationControl
    class SimulationResponse

    package "kernel/simulator/model" #F8F8FF {
      class ModelManager
      class Model
      class ModelInfo
      class ModelSimulation
      class ModelDataManager
      class ModelComponentManager
      abstract class ModelDataDefinition
      class ModelDataDefinitionAssociations
      abstract class ModelComponent
      interface ModelChecker_if
      class ModelCheckerDefaultImpl1
      interface ModelPersistence_if
      class ModelPersistenceDefaultImpl1
    }

    package "kernel/simulator/essentialPlugins" #F8F8FF {
      class StatisticsCollector
      class Entity
      class EntityType
      class Attribute
      class Counter
    }
  }
}

"ListObservable<T>" -up-|> "List<T>"

CollectorDefaultImpl1 -up..|> Collector_if
StatisticsDefaultImpl1 -up..|> Statistics_if
StatisticsDefaultImpl1 o--> "1" Collector_if : collector

SystemShellCommandExecutor -up..|> SystemCommandExecutor_if
SystemDependencyResolver ..> SystemCommandExecutor_if : evaluatesWith
SystemDependencyCheckResult *--> "0..n" SystemDependencyInstallResult : installDiagnostics

ModelDataDefinition -up-|> PersistentObject_base
ModelComponent -up-|> ModelDataDefinition
SourceModelComponent -up-|> ModelComponent
StatisticsCollector -up-|> ModelDataDefinition
Entity -up-|> ModelDataDefinition
EntityType -up-|> ModelDataDefinition
Attribute -up-|> ModelDataDefinition
Counter -up-|> ModelDataDefinition
SimulationResponse -up-|> SimulationControl

ModelCheckerDefaultImpl1 -up..|> ModelChecker_if
ParserDefaultImpl1 -up..|> Parser_if
ModelPersistenceDefaultImpl1 -up..|> ModelPersistence_if

Simulator *--> "1" LicenceManager : _licenceManager
Simulator *--> "1" PluginManager : _pluginManager
Simulator *--> "1" ModelManager : _modelManager
Simulator *--> "1" TraceManager : _traceManager
Simulator *--> "1" ParserManager : _parserManager
Simulator *--> "1" ExperimentManager : _experimentManager

PluginManager o--> "1" Simulator : _simulator
PluginManager *--> "0..n" Plugin : _plugins
PluginManager *--> "0..n" PluginLoadIssue : _pluginLoadIssues
PluginManager *--> "1" PluginConnector_if : _pluginConnector
PluginManager *--> "1" SystemCommandExecutor_if : _systemCommandExecutor
PluginManager ..> SystemDependencyResolver : dependencyPreflight
Plugin *--> "1" PluginInformation : pluginInfo
PluginConnector_if ..> Plugin : check/connect
PluginLoadIssue *--> "0..1" SystemDependencyCheckResult : _systemDependencyResult
PluginInformation *--> "0..n" ParserChangesInformation : parserChanges

ModelManager o--> "1" Simulator : _simulator
ModelManager *--> "0..n" Model : _models
ModelManager o--> "0..1" Model : _currentModel

Model o--> "1" Simulator : _parentSimulator
Model o--> "1" TraceManager : _traceManager
Model *--> "1" OnEventManager : _eventManager
Model *--> "1" ModelDataManager : _modeldataManager
Model *--> "1" ModelComponentManager : _componentManager
Model *--> "1" ModelInfo : _modelInfo
Model *--> "1" ModelSimulation : _simulation
Model *--> "1" ModelPersistence_if : _modelPersistence
Model *--> "1" ModelChecker_if : _modelChecker
Model *--> "1" Parser_if : _parser
Model *--> "0..n" Event : _futureEvents
Model *--> "0..n" SimulationControl : _controls
Model *--> "0..n" SimulationResponse : _responses

ModelDataManager o--> "1" Model : _parentModel
ModelDataManager o--> "0..n" ModelDataDefinition : _datadefinitions
ModelComponentManager o--> "1" Model : _parentModel
ModelComponentManager o--> "0..n" ModelComponent : _components

ModelDataDefinition o--> "1" Model : _parentModel
ModelDataDefinition *--> "1" ModelDataDefinitionAssociations : _dataAssociations
ModelDataDefinition *--> "0..n" SimulationControl : _simulationControls
ModelDataDefinitionAssociations o--> "1" ModelDataDefinition : _owner
ModelDataDefinitionAssociations *--> "0..n" ModelDataDefinition : internalData
ModelDataDefinitionAssociations o--> "0..n" ModelDataDefinition : attachedData

StatisticsCollector o--> "0..1" ModelDataDefinition : _parent
StatisticsCollector *--> "1" Statistics_if : _statistics
Entity o--> "0..1" EntityType : _entityType

ModelComponent *--> "1" ConnectionManager : _connections
ConnectionManager *--> "0..n" Connection : _nextConnections
Connection o--> "1" ModelComponent : component

Event o--> "0..1" Entity : entity
Event o--> "1" ModelComponent : component

ModelSimulation o--> "1" Model : _parentModel
ModelSimulation *--> "0..n" ModelComponent : _breakpointsOnComponent
ModelSimulation *--> "0..n" Entity : _breakpointsOnEntity
ModelSimulation *--> "0..n" StatisticsCollector : _cstatsAndCountersSimulation
ModelSimulation ..> SimulationEvent : creates

OnEventManager *--> "0..n" ModelEvent : modelHandlers
OnEventManager *--> "0..n" SimulationEvent : simulationHandlers
SimulationEvent o--> "1" Model : model
SimulationEvent o--> "0..1" Event : currentEvent
SimulationEvent o--> "0..1" Entity : entity
SimulationEvent o--> "0..1" ModelComponent : component
ModelEvent o--> "1" Model : model

TraceManager o--> "1" Simulator : _simulator
TraceManager *--> "0..n" TraceEvent : traceHandlers
TraceManager *--> "0..n" TraceErrorEvent : errorHandlers
TraceManager *--> "0..n" TraceSimulationEvent : simulationHandlers
TraceSimulationEvent o--> "0..1" Entity : entity
TraceSimulationEvent o--> "0..1" ModelComponent : component

ParserDefaultImpl1 o--> "1" Model : model
ParserDefaultImpl1 o--> "1" Sampler_if : sampler
ModelCheckerDefaultImpl1 o--> "1" Model : model
ModelPersistenceDefaultImpl1 o--> "1" Model : model
ModelPersistenceDefaultImpl1 *--> "1" Persistence : persistence
Persistence *--> "0..n" PersistenceRecord : records
PersistenceRecord ..> PersistentObject_base : serializes

ExperimentManager o--> "1" Simulator : _simulator
ExperimentManager *--> "0..n" SimulationExperiment : experiments
SimulationExperiment o--> "1" Model : model
SimulationExperiment *--> "0..n" SimulationScenario : scenarios
SimulationScenario o--> "0..n" SimulationControl : controls
SimulationScenario o--> "0..n" SimulationResponse : responses

@enduml
