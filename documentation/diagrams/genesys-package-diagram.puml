@startuml
' GenESyS package diagram, branch WiP20261
' Policy: no tests, no CMake targets, no source package, max 3 nesting levels.
' Element background color: #e0e0f0. Alpha omitted for PlantUML compatibility.

left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype ortho
skinparam wrapWidth 120
skinparam backgroundColor white
skinparam package {
  BackgroundColor #e0e0f0
}
skinparam cloud {
  BackgroundColor #e0e0f0
}

package "kernel" {
  package "kernel/util" {}
  package "kernel/statistics" {}
  package "kernel/simulator" {}
}

package "parser" {
  package "parser/parserBisonFlex" {}
}

package "plugins" {
  package "plugins/data" {
    package "plugins/data/BiochemicalSimulation" {}
    package "plugins/data/ExternalIntegration" {}
    package "plugins/data/..." {}
  }

  package "plugins/components" {
    package "plugins/components/BiochemicalSimulation" {}
    package "plugins/components/Continuous" {}
    package "plugins/components/..." {}
  }
}

package "tools" {
  package "tools/FactorialDesign" {}
}

package "applications" {
  package "applications/terminal" {
    package "applications/terminal/GenesysShell" {}
    package "applications/terminal/examples" {}
  }

  package "applications/web" {
    package "applications/web/api" {}
    package "applications/web/auth" {}
    package "applications/web/..." {}
  }

  package "applications/gui" {
    package "applications/gui/qt" {}
  }
}

"plugins" --> "kernel" : extension and model APIs
"parser" --> "kernel" : model and expression semantics
"parser" --> "plugins" : model-data symbols
"tools" --> "kernel" : simulation/statistics services
"applications" --> "kernel" : simulator API
"applications" --> "plugins" : component/data catalog
"applications" --> "parser" : textual model/expression support
"applications" --> "tools" : analysis utilities

@enduml
